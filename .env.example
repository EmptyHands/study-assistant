# ============================================
# Study Assistant 配置文件
# 复制此文件为 .env 并填写实际值
# ============================================

# --- LLM 配置 (OpenAI 兼容接口) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000

# --- Embedding 模型 ---
# provider: openai / local / ollama
EMBEDDING_PROVIDER=local
# openai: text-embedding-3-small | local: all-MiniLM-L6-v2 / bge-small-zh-v1.5 | ollama: nomic-embed-text
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_API_KEY=sk-your-api-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
# local model device: cpu / cuda
EMBEDDING_DEVICE=cpu

# --- Qdrant 向量数据库 ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# --- 搜索 API (可选) ---
SEARCH_API=tavily
SEARCH_API_KEY=tvly-your-key-here

# --- 数据库 ---
DATABASE_URL=sqlite:///./data/study_assistant.db

# --- 应用配置 ---
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# --- Agent 配置 ---
AGENT_MAX_STEPS=5
AGENT_TIMEOUT=300

# --- 两阶段检索 ---
# 粗排召回量（向量检索 top_k）
COARSE_TOP_K=20
# 精排后保留数（送入 LLM 的条数）
FINE_TOP_K=5
# Cross-Encoder 重排序模型
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# 模型缓存目录
RERANKER_CACHE_DIR=E:/models
